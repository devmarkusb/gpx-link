root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
# Python uses 4 spaces (PEP 8) — inherits from [*]

[*.toml]
indent_size = 4

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.json]
indent_size = 2

[*.md]
# Markdown: trailing spaces can be intentional (hard line break)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
